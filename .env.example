# Local dev default - leave as "development". Set MODE=production explicitly
# in your deployment host's env vars (Render, etc.) to enable deploy-only UI
# (e.g. the "paste a key" nudge banner). Absence of this var anywhere is
# treated as "development" - a host that forgets to set it just gets the
# quieter local behavior, never mistakenly production-only messaging.
MODE=development

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
