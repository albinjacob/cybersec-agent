.env
__pycache__/
*.pyc

# Debug dump regenerated on every run; output/report.md is kept as a demo backup.
output/state.json

# Local tooling lock file
.claude/scheduled_tasks.lock

# Trivy binary downloaded by scripts/render_build.sh - not committed
bin/

# Local eval run history - only used when Supabase isn't configured
evals/results/history.jsonl

# Per-provider embedding cache for policy RAG - regenerated on demand via
# the "Rebuild Index" button, not committed source data
data/knowledgebase/policy_index_meta.*.json
data/knowledgebase/policy_index_vectors.*.npy
